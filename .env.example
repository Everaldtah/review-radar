# Database
DB_PATH=reviews.db

# Google Places API (for fetching Google reviews)
GOOGLE_PLACES_API_KEY=AIza...

# Yelp Fusion API (for fetching Yelp reviews)
YELP_API_KEY=your_yelp_fusion_api_key

# OpenAI (optional — enables AI-drafted responses)
OPENAI_API_KEY=sk-...

# Alert webhook (Slack incoming webhook URL or any HTTP endpoint)
WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../xxx

# How often to poll for new reviews (in minutes)
POLL_INTERVAL_MINUTES=60
