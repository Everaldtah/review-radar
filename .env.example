# Database
DB_PATH=review_radar.db

# Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=your@gmail.com

# App
PORT=8001
ENV=development

# Scraping (optional delay between requests in seconds)
SCRAPE_DELAY=2.0

# Weekly digest (cron — default Monday 8 AM)
DIGEST_CRON_HOUR=8
DIGEST_CRON_DAY_OF_WEEK=mon
